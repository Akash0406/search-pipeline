# =============================================================================
# CareerStack (CareerRadar AI) — example environment
# =============================================================================
# Copy this file to `.env` and adjust as needed:
#   cp .env.example .env
#
# LOCAL defaults only — never reuse these credentials in a shared or production
# environment. This file is committed; do NOT put real secrets here.
#
# Variable names are the single source of truth consumed by:
#   - packages/config          (typed application config loader)
#   - infra/docker-compose.yml (local Postgres + Redis + MinIO)
# Keep the two in sync when adding new configuration.
# =============================================================================

# -----------------------------------------------------------------------------
# Application (Capability A)
# -----------------------------------------------------------------------------
# Display/brand name. Falls back to a defined default ("CareerStack") and logs
# a warning when unset (Req 1.1, 1.3).
BRAND_NAME=CareerStack
# development | test | production
NODE_ENV=development

# -----------------------------------------------------------------------------
# Safe-fetch bounds (Req 31.3, 31.4, 31.5)
# -----------------------------------------------------------------------------
FETCH_MAX_BYTES=5000000
FETCH_TIMEOUT_MS=10000
FETCH_MAX_REDIRECTS=5
FETCH_USER_AGENT=CareerStackBot/1.0 (+https://careerstack.example/bot)
# Comma/space-separated lists (optional; deny beats allow)
FETCH_ALLOWED_DOMAINS=
FETCH_DENIED_DOMAINS=

# -----------------------------------------------------------------------------
# Per-domain rate limiting (Req 27.1, 27.3)
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_DOMAIN_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_MS=1000
RATE_LIMIT_MAX_RETRIES=5
RATE_LIMIT_BACKOFF_BASE_MS=500

# -----------------------------------------------------------------------------
# Raw-source retention (Req 53.1) — days to keep raw artifacts before cleanup
# NOTE: variable name must match packages/config (RAW_RETENTION_DAYS).
# -----------------------------------------------------------------------------
RAW_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# Auth — Google OAuth (Req 4). Read from env; never hardcoded. (required)
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/google/callback

# -----------------------------------------------------------------------------
# Auth — Magic link (Req 5.4: TTL must be <= 15 minutes)
# -----------------------------------------------------------------------------
MAGIC_LINK_TTL_MINUTES=15

# -----------------------------------------------------------------------------
# Auth — Session cookie
# -----------------------------------------------------------------------------
SESSION_COOKIE_NAME=cs_session
# MUST be at least 32 chars (required)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
SESSION_TTL_HOURS=720
SESSION_COOKIE_SECURE=true
# strict | lax | none
SESSION_COOKIE_SAME_SITE=lax

# -----------------------------------------------------------------------------
# PostgreSQL (with pgvector) — consumed by packages/config + packages/database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://careerstack:careerstack@localhost:5432/careerstack
# Individual values used by docker-compose to provision the Postgres container.
POSTGRES_USER=careerstack
POSTGRES_PASSWORD=careerstack
POSTGRES_DB=careerstack
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis (BullMQ queues + per-domain rate limiter)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Object storage (S3-compatible; MinIO locally) — raw artifact storage (Req 32.1)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=careerstack-artifacts
S3_ACCESS_KEY_ID=careerstack
S3_SECRET_ACCESS_KEY=careerstack-secret
S3_FORCE_PATH_STYLE=true

# MinIO container provisioning values (used by docker-compose). These back the
# S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY above so the app and store agree.
MINIO_ROOT_USER=careerstack
MINIO_ROOT_PASSWORD=careerstack-secret
MINIO_BUCKET=careerstack-artifacts
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
