{
  "name": "@careerstack/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "start": "node --env-file=../../.env dist/main.js",
    "dev": "node --watch --env-file=../../.env dist/main.js",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@careerstack/auth": "workspace:*",
    "@careerstack/config": "workspace:*",
    "@careerstack/connectors": "workspace:*",
    "@careerstack/contracts": "workspace:*",
    "@careerstack/database": "workspace:*",
    "@careerstack/observability": "workspace:*",
    "@aws-sdk/client-s3": "3.1085.0",
    "@aws-sdk/s3-request-presigner": "3.1085.0",
    "@fastify/cookie": "^9.4.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-fastify": "^10.4.15",
    "bullmq": "5.80.1",
    "drizzle-orm": "^0.38.3",
    "fastify": "^4.28.1",
    "google-auth-library": "^9.15.0",
    "ioredis": "5.11.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  }
}
