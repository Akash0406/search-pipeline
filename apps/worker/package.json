{
  "name": "@careerstack/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "start": "node dist/main.js",
    "dev": "node --watch dist/main.js",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1085.0",
    "@careerstack/config": "workspace:*",
    "@careerstack/connectors": "workspace:*",
    "@careerstack/database": "workspace:*",
    "@careerstack/observability": "workspace:*",
    "@careerstack/security": "workspace:*",
    "@careerstack/shared": "workspace:*",
    "bullmq": "5.80.1",
    "drizzle-orm": "^0.38.3",
    "ioredis": "5.11.1"
  }
}
